# TikTok Monitor - 环境变量配置模板
# 复制此文件为 .env 并填入你的配置信息
# 注意：.env 文件已加入 .gitignore，不会被提交到版本控制系统
#
# 📖 详细配置指南：请查阅 SETUP_GUIDE.md

# ==================== AI 模型配置 ====================
# 使用 Gemini API（推荐）
# 从 https://aistudio.google.com/apikey 获取你的 API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini 模型名称（默认: gemini-2.5-flash）
# 可用模型:  gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-pro, gemini-1.5-pro 等
GEMINI_MODEL=gemini-2.5-flash

# ==================== 抓取配置 ====================
# 每次最多抓取视频数量
MAX_VIDEOS_PER_FETCH=20

# ==================== 调度器配置 ====================
# 自动抓取开关: 0=关闭, 1=开启
AUTO_FETCH_ENABLED=0

# 自动抓取间隔（小时）
FETCH_INTERVAL=1.0

# ==================== 下载配置 ====================
# 视频下载保存路径（留空则使用默认路径）
# Windows 示例: C:\Users\YourName\Downloads\TikTok_Monitor
# Mac/Linux 示例: /Users/YourName/Downloads/TikTok_Monitor
DOWNLOAD_PATH=

# ==================== 代理配置 ====================
# 如果需要代理访问 TikTok，取消注释并填入代理地址
# 支持 HTTP/HTTPS/SOCKS5 代理
PROXY_URL=
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ==================== 日志配置 ====================
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
